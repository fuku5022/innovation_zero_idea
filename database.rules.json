{
  "rules": {
    "boardList": {
      ".read": true,
      ".write": true
    },
    "boards": {
      "$boardId": {
        ".read": true,
        ".write": true,
        "notes": {
          "$noteId": {
            ".validate": "newData.hasChildren(['x', 'y', 'color'])"
          }
        }
      }
    }
  }
}
